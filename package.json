{
  "name": "mfexplorer",
  "version": "0.0.2",
  "description": "An alternative to the bloated outdated File Explorer included with Windows.",
  "license": "MIT",
  "author": "MadGames",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.madgames.mfexplorer",
    "productName": "MFExplorer",
    "icon": "src/misc/icon.ico",
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "package.json",
      "src/**/*",
      "renderer/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "fswin": "^3.25.1108"
  }
}
